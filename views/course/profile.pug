extends ../layout

block content
    nav
        ul
            li
                a(href=`/teachers`) View Teachers
            li
                a(href=`/courses`) View Courses

    h3 #{course.name}
    div
        p Department: #{course.department}
        p Grade Levels: #{course.grade_levels}
    h3 Courses' Teachers
        table
            thead
            tr
                th Name
                th Room
                th Email
            tbody
                each teacher in course.teachers
                    tr
                        td
                            a(href=`/teachers/profile/${teacher.id}`)= `${teacher.first_name} ${teacher.last_name}`
                        td= teacher.room
                        td
                            a(href=`mailto:${teacher.email}`)= teacher.email