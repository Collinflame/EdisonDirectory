extends ../layout

block content
    include ../CourseProfile
    div(id="outer" class="removePopup")
        div(id="inner" class="removePopup")
            +courseProfile(course)
    h3 Courses
        h4 Filters
            form(action='/courses/' method='get')
                label(for="department") Department
                select(id="department" name="department" autocomplete="off")
                    each department in departmentChoices
                        option(value=department selected = (department === searchDepartment)) #{department}
                label(for="department") Class Type
                select(id="classType" name="classType" autocomplete="off")
                    each classType in classTypeChoices
                        option(value=classType selected = (classType === searchClassType)) #{classType}
                input(id="ninth" name="ninth" type="checkbox" value="ninth")
                label(for="ninth") Ninth Grade Classes
                input(id="tenth" name="tenth" type="checkbox" value="tenth")
                label(for="tenth") Tenth Grade Classes
                input(id="eleventh" name="eleventh" type="checkbox" value="eleventh")
                label(for="eleventh") Eleventh Grade Classes
                input(id="twelfth" name="twelfth" type="checkbox" value="twelfth")
                label(for="twelfth") Twelfth Grade Classes
                button(type='submit') Filter
        table
            thead
                tr
                    th Name
                    th Department
                    th Grade levels
            tbody
                each course in sortedCourses
                    tr
                        td
                            a(href=`/courses/?name=${course.name}` class="courses")= course.name
                        td= course.department
                        td= course.grade_levels
    script.
        let courses = document.querySelectorAll(".courses")
        courses.forEach(element => {
            element.addEventListener("click", function () {
                localStorage.setItem('coursePopup', 'true')
            });

        });
        document.getElementById("remove").addEventListener("click", function () {
            localStorage.setItem('coursePopup', 'false')
            window.location.reload();
        })
        document.addEventListener("DOMContentLoaded", function () {
            if (!window.location.href.includes("?name=")) {
                localStorage.setItem('coursePopup', 'false')
            }
            if (localStorage.getItem('coursePopup') === 'true') {
                document.getElementById("inner").className = ('popupOverlay');
                document.getElementById("outer").className = ('popupOuter');
                document.getElementById("courseProfile").className = ('profileContent');
            } else {
                document.getElementById("inner").className = ('removePopup');
                document.getElementById("outer").className = ('removePopup');
                document.getElementById("courseProfile").className = ('removeProfileContent');
            }
        })